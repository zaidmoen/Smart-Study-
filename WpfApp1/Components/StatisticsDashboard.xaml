<UserControl x:Class="WpfApp1.Components.StatisticsDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="تحليلات الأداء" Style="{StaticResource PanelTitleStyle}" />

        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
            <Border Style="{StaticResource PanelCardStyle}" Margin="10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="إجمالي ساعات الدراسة" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock Text="24.5" FontSize="36" FontWeight="Bold" Foreground="#FF2563EB" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelCardStyle}" Margin="10">
                 <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="المهام المنجزة" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock Text="42" FontSize="36" FontWeight="Bold" Foreground="#FF14B8A6" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelCardStyle}" Grid.ColumnSpan="2" Margin="10">
                <Grid>
                    <TextBlock Text="توزيع المواد" Style="{StaticResource FieldLabelStyle}" Margin="10" />
                    <!-- Placeholder for a chart -->
                    <Canvas Margin="20,40,20,20">
                        <Rectangle Width="40" Height="100" Fill="#FF14B8A6" Canvas.Bottom="0" Canvas.Left="20" />
                        <Rectangle Width="40" Height="150" Fill="#FF0EA5E9" Canvas.Bottom="0" Canvas.Left="80" />
                        <Rectangle Width="40" Height="80" Fill="#FFF97316" Canvas.Bottom="0" Canvas.Left="140" />
                        <Rectangle Width="40" Height="120" Fill="#FF2563EB" Canvas.Bottom="0" Canvas.Left="200" />
                    </Canvas>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
