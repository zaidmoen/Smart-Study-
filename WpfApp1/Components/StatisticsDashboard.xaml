<UserControl x:Class="WpfApp1.Components.StatisticsDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             d:DesignHeight="620"
             d:DesignWidth="820">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="مركز التحليلات"
                               Style="{StaticResource PanelTitleStyle}" />
                    <TextBlock Text="{Binding SubjectAnalyticsSubtitle}"
                               Margin="0,8,0,0"
                               Style="{StaticResource PanelSubtitleStyle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFF3F4F6"
                        CornerRadius="18"
                        Padding="14,10"
                        Margin="18,0,0,0"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding ProductivityGradeText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#FF0F172A" />
                </Border>
            </Grid>

            <UniformGrid Columns="4"
                         Margin="0,22,0,18">
                <Border Style="{StaticResource PanelCardStyle}"
                        Padding="18"
                        Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="وقت منجز"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding TotalStudyHoursText}"
                                   Margin="0,10,0,0"
                                   FontSize="27"
                                   FontWeight="Bold"
                                   Foreground="#FF2563EB"
                                   TextAlignment="Right" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}"
                        Padding="18"
                        Margin="4,0,6,0">
                    <StackPanel>
                        <TextBlock Text="نسبة الإنجاز"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding CompletionRateText}"
                                   Margin="0,10,0,0"
                                   FontSize="27"
                                   FontWeight="Bold"
                                   Foreground="#FF14B8A6"
                                   TextAlignment="Right" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}"
                        Padding="18"
                        Margin="6,0,4,0">
                    <StackPanel>
                        <TextBlock Text="الحمل المتبقي"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding RemainingWorkText}"
                                   Margin="0,10,0,0"
                                   FontSize="27"
                                   FontWeight="Bold"
                                   Foreground="#FFF97316"
                                   TextAlignment="Right" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}"
                        Padding="18"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="المهام العاجلة"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding UrgentWorkText}"
                                   Margin="0,10,0,0"
                                   FontSize="27"
                                   FontWeight="Bold"
                                   Foreground="#FFEF4444"
                                   TextAlignment="Right" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FF111827"
                        CornerRadius="30"
                        Padding="24"
                        Margin="0,0,10,0"
                        Effect="{StaticResource SoftShadowEffect}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="درجة التركيز"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFD9B8"
                                   TextAlignment="Right" />

                        <Grid Grid.Row="1"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding PrimaryInsightTitle}"
                                       FontFamily="Bahnschrift"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FocusScoreText}"
                                       Margin="18,0,0,0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#FF14B8A6"
                                       VerticalAlignment="Top" />
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding PrimaryInsightBody}"
                                   Margin="0,12,0,18"
                                   FontSize="13"
                                   Foreground="#D7F8FAFC"
                                   TextWrapping="Wrap"
                                   TextAlignment="Right" />

                        <StackPanel Grid.Row="3">
                            <Border Background="#22FFFFFF"
                                    Height="10"
                                    CornerRadius="999">
                                <Border Width="{Binding FocusScoreWidth}"
                                        Height="10"
                                        Background="#FF14B8A6"
                                        CornerRadius="999"
                                        HorizontalAlignment="Left" />
                            </Border>

                            <TextBlock Text="{Binding WorkloadBalanceText}"
                                       Margin="0,12,0,0"
                                       FontSize="12"
                                       Foreground="#B3E2E8F0"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="24"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="قرار الآن"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding BestNextActionText}"
                                   Margin="0,12,0,18"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#FF0F172A"
                                   TextWrapping="Wrap"
                                   TextAlignment="Right" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="#FFF8FAFB"
                                    CornerRadius="18"
                                    Padding="14"
                                    Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="متوسط الجلسة"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding AverageFocusText}"
                                               Margin="0,8,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FF0F172A"
                                               TextAlignment="Right" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="#FFF8FAFB"
                                    CornerRadius="18"
                                    Padding="14"
                                    Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="حالة الحفظ"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding StorageHealthText}"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#FF0F766E"
                                               TextWrapping="Wrap"
                                               TextAlignment="Right" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button Content="ابدأ جلسة التركيز"
                                Command="{Binding StartFocusCommand}"
                                Margin="0,18,0,0"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="22"
                        Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="توزيع المواد"
                                   Style="{StaticResource PanelTitleStyle}"
                                   FontSize="21" />

                        <ItemsControl ItemsSource="{Binding Subjects}"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding SoftAccentBrush}"
                                            CornerRadius="20"
                                            Padding="14"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="#FF0F172A"
                                                           TextAlignment="Right" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ShareLabel}"
                                                           Margin="12,0,0,0"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FF475569" />
                                            </Grid>

                                            <TextBlock Text="{Binding EffortSummary}"
                                                       Margin="0,6,0,10"
                                                       FontSize="12"
                                                       Foreground="#7A334155"
                                                       TextAlignment="Right" />

                                            <Border Background="#33FFFFFF"
                                                    Height="8"
                                                    CornerRadius="999">
                                                <Border Width="{Binding ShareWidth}"
                                                        Height="8"
                                                        Background="{Binding AccentBrush}"
                                                        CornerRadius="999"
                                                        HorizontalAlignment="Left" />
                                            </Border>

                                            <TextBlock Text="{Binding RemainingSummary}"
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF0F172A"
                                                       TextAlignment="Right" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="22"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="خطة الساعات القادمة"
                                   Style="{StaticResource PanelTitleStyle}"
                                   FontSize="21" />

                        <ItemsControl ItemsSource="{Binding TodaySessions}"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding SoftAccentBrush}"
                                            CornerRadius="20"
                                            Padding="14"
                                            Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Subject}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="#FF0F172A"
                                                           TextAlignment="Right" />
                                                <TextBlock Text="{Binding Topic}"
                                                           Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="#7A334155"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Right" />
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Background="{Binding AccentBrush}"
                                                    CornerRadius="999"
                                                    Padding="10,6"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding TimeRange}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
