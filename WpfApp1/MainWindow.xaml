<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart Study Planner"
        Width="1520"
        Height="930"
        MinWidth="1280"
        MinHeight="780"
        Background="#FFF7F1E7"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadowEffect"
                          BlurRadius="28"
                          ShadowDepth="0"
                          Opacity="0.18"
                          Color="#FF0F172A" />

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF111827" Offset="0" />
            <GradientStop Color="#FF163A53" Offset="0.55" />
            <GradientStop Color="#FF0F766E" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF97316" Offset="0" />
            <GradientStop Color="#FFEA580C" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F9FFFFFF" />
            <Setter Property="BorderBrush" Value="#12FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Effect" Value="{StaticResource SoftShadowEffect}" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#110F172A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Effect" Value="{StaticResource SoftShadowEffect}" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF0F172A" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style x:Key="PanelSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#7A334155" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource AccentButtonBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#FF0F172A" />
            <Setter Property="Background" Value="#FFF3F4F6" />
        </Style>

        <Style x:Key="DarkButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#1EFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8A334155" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFF8FAFB" />
            <Setter Property="BorderBrush" Value="#FFD8E1E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FlowDirection" Value="RightToLeft" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFF8FAFB" />
            <Setter Property="BorderBrush" Value="#FFD8E1E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FlowDirection" Value="RightToLeft" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <Style x:Key="TaskCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box"
                                Background="#FFF1F5F9"
                                BorderBrush="#FFD0D8E2"
                                BorderThickness="1.5"
                                CornerRadius="14">
                            <TextBlock x:Name="Tick"
                                       Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="White"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FF14B8A6" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF14B8A6" />
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="520" Height="520" Fill="#10FB923C" Canvas.Left="-180" Canvas.Top="-120" />
            <Ellipse Width="380" Height="380" Fill="#127DD3FC" Canvas.Right="-120" Canvas.Top="40" />
            <Ellipse Width="300" Height="300" Fill="#10F97316" Canvas.Right="320" Canvas.Bottom="-120" />
        </Canvas>

        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource HeroBrush}"
                    CornerRadius="34"
                    Padding="26"
                    Margin="0,0,20,0"
                    Effect="{StaticResource SoftShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Border Background="#18FFFFFF"
                                CornerRadius="999"
                                Padding="12,6"
                                HorizontalAlignment="Right">
                            <TextBlock Text="ELITE STUDY OS"
                                       FontFamily="Bahnschrift"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFD9B8" />
                        </Border>

                        <TextBlock Text="Smart&#x0a;Study"
                                   Margin="0,22,0,8"
                                   FontFamily="Bahnschrift"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Right" />

                        <TextBlock Text="واجهة دراسة ترفع هيبة يومك: وضوح، ضغط محسوب، وزخم يخليك تغلق المهام بدل تدويرها."
                                   FontSize="14"
                                   Foreground="#C7F8FAFC"
                                   TextWrapping="Wrap"
                                   TextAlignment="Right" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#14FFFFFF"
                            CornerRadius="26"
                            Padding="18"
                            Margin="0,24,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,12">
                                    <TextBlock Text="أنجزت"
                                               FontSize="12"
                                               Foreground="#B3E2E8F0"
                                               TextAlignment="Right" />
                                    <TextBlock Text="{Binding CompletedTasksText}"
                                               Margin="0,6,0,0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Right" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="المتبقي"
                                               FontSize="12"
                                               Foreground="#B3E2E8F0"
                                               TextAlignment="Right" />
                                    <TextBlock Text="{Binding PendingTasksText}"
                                               Margin="0,6,0,0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Right" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="العاجلة"
                                               FontSize="12"
                                               Foreground="#B3E2E8F0"
                                               TextAlignment="Right" />
                                    <TextBlock Text="{Binding UrgentTasksText}"
                                               Margin="0,6,0,0"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFD9B8"
                                               TextAlignment="Right" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="دقائق الخطة"
                                               FontSize="12"
                                               Foreground="#B3E2E8F0"
                                               TextAlignment="Right" />
                                    <TextBlock Text="{Binding PlannedMinutesText}"
                                               Margin="0,6,0,0"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFD9B8"
                                               TextAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#FFF7EFE3"
                            CornerRadius="28"
                            Padding="20"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="مهمة اليوم"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFB45309"
                                       TextAlignment="Right" />
                            <TextBlock Text="{Binding DailyMissionText}"
                                       Margin="0,10,0,14"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       Foreground="#FF0F172A"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right" />

                            <TextBlock Text="{Binding OverallProgressText}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#FF0F172A"
                                       TextAlignment="Right" />
                            <TextBlock Text="{Binding OverallProgressSubtitle}"
                                       Margin="0,4,0,10"
                                       FontSize="12"
                                       Foreground="#7A334155"
                                       TextAlignment="Right" />

                            <Border Background="#1AF97316"
                                    Height="10"
                                    CornerRadius="999">
                                <Border Width="{Binding OverallProgressWidth}"
                                        Height="10"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentButtonBrush}"
                                        CornerRadius="999" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,20,0,0">
                        <Border Background="#14FFFFFF"
                                CornerRadius="24"
                                Padding="18"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="سلسلة الزخم"
                                           FontSize="12"
                                           Foreground="#B3E2E8F0"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding StudyStreakText}"
                                           Margin="0,8,0,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding MomentumText}"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="#D7F8FAFC"
                                           TextWrapping="Wrap"
                                           TextAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <Border Background="#14FFFFFF"
                                CornerRadius="24"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentDateText}"
                                           FontSize="12"
                                           Foreground="#B3E2E8F0"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding CurrentTimeText}"
                                           Margin="0,8,0,10"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           TextAlignment="Right" />

                                <Button Content="ابدأ جلسة تركيز"
                                        Click="StartFocus_Click"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="بدّل الاقتراح الذكي"
                                        Click="GenerateSmartPlan_Click"
                                        Margin="0,10,0,0"
                                        Style="{StaticResource DarkButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Margin="0,18,0,0"
                               FontSize="12"
                               Foreground="#B3E2E8F0"
                               Text="اسحب يومك من الفوضى إلى السيطرة: مهمة واضحة، وقت واضح، وإنهاء واضح."
                               TextAlignment="Right"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource PanelCardStyle}"
                    Padding="26"
                    Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="قاعدة المهام"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <TextBlock Text="{Binding TaskListSubtitle}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource PanelSubtitleStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="18,0,0,0"
                                    HorizontalAlignment="Right">
                            <Border Background="#FFF3F4F6"
                                    CornerRadius="18"
                                    Padding="14,10">
                                <TextBlock Text="{Binding TaskHeatText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#FF0F172A" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#FFF9FAFB"
                            CornerRadius="28"
                            Padding="20"
                            Margin="0,24,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.1*" />
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="المهمة"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Margin="0,8,0,0"
                                         Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="اكتب اسم المهمة الدراسية" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="المادة"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Margin="0,8,0,0"
                                         Text="{Binding SelectedSubjectOption, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="اكتب اسم المادة (مثلاً: الفيزياء، تاريخ...)" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                <TextBlock Text="المدة"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Margin="0,8,0,0"
                                         Text="{Binding SelectedDurationOption, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="اكتب المدة بالدقائق (مثلاً: 45)" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="14,0,0,0">
                                <TextBlock Text="الأولوية"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox Margin="0,8,0,0"
                                          ItemsSource="{Binding PriorityOptions}"
                                          SelectedItem="{Binding SelectedPriorityOption}" />
                            </StackPanel>

                            <Button Grid.Column="4"
                                    Content="إضافة فخمة"
                                    Margin="16,28,0,0"
                                    Click="AddTask_Click"
                                    Height="52"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#FFF4F8F7"
                                CornerRadius="22"
                                Padding="18"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="المسار التالي"
                                           FontSize="12"
                                           Foreground="#7A334155"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding NextSessionText}"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FF0F172A"
                                           TextWrapping="Wrap"
                                           TextAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#FFF8F4EC"
                                CornerRadius="22"
                                Padding="18"
                                Margin="6,0,6,0">
                            <StackPanel>
                                <TextBlock Text="نافذة التركيز"
                                           FontSize="12"
                                           Foreground="#7A334155"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding FocusLaneText}"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FF0F172A"
                                           TextWrapping="Wrap"
                                           TextAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#FFF2F5FB"
                                CornerRadius="22"
                                Padding="18"
                                Margin="12,0,0,0">
                            <StackPanel>
                                <TextBlock Text="أفضل مادة"
                                           FontSize="12"
                                           Foreground="#7A334155"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding WinningSubjectText}"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FF0F172A"
                                           TextWrapping="Wrap"
                                           TextAlignment="Right" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding StudyTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SurfaceCardStyle}"
                                                Padding="18"
                                                Margin="0,0,0,16"
                                                Opacity="{Binding CardOpacity}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Background="{Binding AccentBrush}"
                                                        CornerRadius="999" />

                                                <Border Grid.Column="1"
                                                        Width="50"
                                                        Height="50"
                                                        Margin="16,0,18,0"
                                                        VerticalAlignment="Top"
                                                        Background="{Binding SoftAccentBrush}"
                                                        CornerRadius="25">
                                                    <TextBlock Text="{Binding SubjectInitial}"
                                                               FontFamily="Bahnschrift"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="#FF0F172A"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="18"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FF0F172A"
                                                                   TextAlignment="Right">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="TextDecorations" Value="{x:Null}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <Border Grid.Column="1"
                                                                Margin="12,0,0,0"
                                                                Background="#FFF8FAFB"
                                                                CornerRadius="999"
                                                                Padding="10,5">
                                                            <TextBlock Text="{Binding TaskLaneText}"
                                                                       FontFamily="Bahnschrift"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF0F172A" />
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Margin="10,0,0,0"
                                                                Background="{Binding AccentBrush}"
                                                                CornerRadius="999"
                                                                Padding="10,5">
                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White" />
                                                        </Border>
                                                    </Grid>

                                                    <TextBlock Text="{Binding Subject}"
                                                               Margin="0,8,0,0"
                                                               FontSize="13"
                                                               Foreground="#7A334155"
                                                               TextAlignment="Right" />

                                                    <TextBlock Text="{Binding StudyMode}"
                                                               Margin="0,6,0,0"
                                                               FontSize="13"
                                                               Foreground="#FF475569"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Right" />

                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Margin="0,14,0,0">
                                                        <Border Background="#FFF8FAFB"
                                                                CornerRadius="999"
                                                                Padding="12,6">
                                                            <TextBlock Text="{Binding DueText}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF0F172A" />
                                                        </Border>
                                                        <Border Background="#FFF8FAFB"
                                                                CornerRadius="999"
                                                                Padding="12,6"
                                                                Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding EstimateText}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF0F172A" />
                                                        </Border>
                                                        <Border Background="#FFF8FAFB"
                                                                CornerRadius="999"
                                                                Padding="12,6"
                                                                Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding ConfidenceText}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF0F172A" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>

                                                <CheckBox Grid.Column="3"
                                                          Margin="18,4,0,0"
                                                          VerticalAlignment="Top"
                                                          IsChecked="{Binding IsDone, Mode=TwoWay}"
                                                          Style="{StaticResource TaskCheckBoxStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel VerticalAlignment="Center" 
                                        HorizontalAlignment="Center" 
                                        Margin="0,80,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTaskListEmpty}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Border Width="80" Height="80" 
                                        Background="#101827" 
                                        CornerRadius="40" 
                                        Margin="0,0,0,20">
                                    <TextBlock Text="&#xE710;" 
                                               FontFamily="Segoe MDL2 Assets" 
                                               Foreground="White" 
                                               FontSize="32" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="ابدأ رحلتك الدراسية" 
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="#101827" 
                                           TextAlignment="Center" />
                                <TextBlock Text="أضف مادة ومهمة من الأعلى لتنظيم يومك باحترافية." 
                                           FontSize="14" 
                                           Foreground="#7A334155" 
                                           TextAlignment="Center" 
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Background="#FF101827"
                            CornerRadius="32"
                            Padding="22"
                            Margin="0,0,0,18"
                            Effect="{StaticResource SoftShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="غرفة التركيز"
                                       FontFamily="Bahnschrift"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextAlignment="Right" />
                            <TextBlock Text="{Binding SmartRecommendationTitle}"
                                       Margin="0,14,0,8"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#FFFFD9B8"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right" />
                            <TextBlock Text="{Binding SmartRecommendationBody}"
                                       FontSize="13"
                                       Foreground="#D7F8FAFC"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Padding="22"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="جلسات اليوم"
                                       Style="{StaticResource PanelTitleStyle}"
                                       FontSize="21" />
                            <ItemsControl ItemsSource="{Binding TodaySessions}" Margin="0,16,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding SoftAccentBrush}"
                                                CornerRadius="22"
                                                Padding="16"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="44"
                                                        Height="44"
                                                        Background="{Binding AccentBrush}"
                                                        CornerRadius="22">
                                                    <TextBlock Text="{Binding SubjectInitial}"
                                                               FontFamily="Bahnschrift"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                    <TextBlock Text="{Binding Subject}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="#FF0F172A"
                                                               TextAlignment="Right" />
                                                    <TextBlock Text="{Binding Topic}"
                                                               Margin="0,6,0,0"
                                                               FontSize="12"
                                                               Foreground="#7A334155"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Right" />
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Margin="0,10,0,0">
                                                        <Border Background="#FFFFFFFF"
                                                                CornerRadius="999"
                                                                Padding="10,5">
                                                            <TextBlock Text="{Binding TimeRange}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#FF0F172A" />
                                                        </Border>
                                                        <Border Background="{Binding AccentBrush}"
                                                                CornerRadius="999"
                                                                Padding="10,5"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding SessionLabel}"
                                                                       FontFamily="Bahnschrift"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Padding="22"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="حالة المواد"
                                       Style="{StaticResource PanelTitleStyle}"
                                       FontSize="21" />
                            <TextBlock Text="{Binding RecoverySubjectText}"
                                       Margin="0,10,0,14"
                                       Style="{StaticResource PanelSubtitleStyle}" />

                            <ItemsControl ItemsSource="{Binding Subjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF8FAFB"
                                                CornerRadius="22"
                                                Padding="16"
                                                Margin="0,0,0,12">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="#FF0F172A"
                                                               TextAlignment="Right" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CompletionLabel}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="#FF0F766E"
                                                               TextAlignment="Right" />
                                                </Grid>

                                                <TextBlock Text="{Binding StatusText}"
                                                           Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="#7A334155"
                                                           TextAlignment="Right" />

                                                <Border Background="#140F766E"
                                                        Height="8"
                                                        CornerRadius="999"
                                                        Margin="0,12,0,0">
                                                    <Border Width="{Binding ProgressWidth}"
                                                            Height="8"
                                                            Background="{Binding AccentBrush}"
                                                            CornerRadius="999"
                                                            HorizontalAlignment="Left" />
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Padding="22">
                        <StackPanel>
                            <TextBlock Text="قوانين الفوز"
                                       Style="{StaticResource PanelTitleStyle}"
                                       FontSize="21" />

                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="10" Height="10" Fill="#FF14B8A6" Margin="0,4,12,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="أغلق أهم مهمة أولًا حتى لو كانت أصغر من المثالي."
                                               FontSize="13"
                                               Foreground="#FF475569"
                                               TextWrapping="Wrap"
                                               TextAlignment="Right" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="10" Height="10" Fill="#FFF97316" Margin="0,4,12,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="المادة الأضعف تحتاج لمسة يومية قصيرة، لا انتظار المزاج."
                                               FontSize="13"
                                               Foreground="#FF475569"
                                               TextWrapping="Wrap"
                                               TextAlignment="Right" />
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="10" Height="10" Fill="#FF2563EB" Margin="0,4,12,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="إنهاء مهمتين ثقيلتين أهم من فتح خمس مهام جديدة."
                                               FontSize="13"
                                               Foreground="#FF475569"
                                               TextWrapping="Wrap"
                                               TextAlignment="Right" />
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
